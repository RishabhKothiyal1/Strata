# ==============================================================================
# NovaBase Environment Variables Configuration
# ==============================================================================

# System environment (development, production)
NODE_ENV=development

# Database configuration (PostgreSQL)
POSTGRES_USER=novabase_admin
POSTGRES_PASSWORD=novabase_secure_pass_123
POSTGRES_DB=novabase
POSTGRES_PORT=5432

# Redis cache & sessions
REDIS_PASSWORD=redis_secure_pass_123
REDIS_PORT=6379

# MinIO object storage
MINIO_ROOT_USER=novabase_storage_admin
MINIO_ROOT_PASSWORD=minio_secure_pass_123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# NATS messaging system
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Grafana monitoring
GRAFANA_ADMIN_PASSWORD=grafana_secure_pass_123
GRAFANA_PORT=3000

# Prometheus monitoring
PROMETHEUS_PORT=9090

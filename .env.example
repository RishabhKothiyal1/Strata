# ==============================================================================
# Strata Environment Variables Configuration
# ==============================================================================

# System environment (development, production)
NODE_ENV=development

# Database configuration (PostgreSQL)
POSTGRES_USER=strata_admin
POSTGRES_PASSWORD=strata_secure_pass_123
POSTGRES_DB=strata
POSTGRES_PORT=5432

# Redis cache & sessions
REDIS_PASSWORD=redis_secure_pass_123
REDIS_PORT=6379

# MinIO object storage
MINIO_ROOT_USER=strata_storage_admin
MINIO_ROOT_PASSWORD=minio_secure_pass_123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# NATS messaging system
NATS_PORT=4222
NATS_MONITORING_PORT=8222

# Grafana monitoring
GRAFANA_ADMIN_PASSWORD=grafana_secure_pass_123
GRAFANA_PORT=3000

# AI provider encryption key (64 hex chars = 32 bytes AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_change_me_1234567890abcdef

# Prometheus monitoring
PROMETHEUS_PORT=9090
